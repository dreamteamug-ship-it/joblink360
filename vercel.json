{
    "buildCommand":  "npm run build",
    "builds":  [
                   {
                       "config":  {
                                      "includeFiles":  [
                                                           "next.config.js",
                                                           "package.json",
                                                           "yarn.lock",
                                                           "pnpm-lock.yaml",
                                                           "package-lock.json"
                                                       ]
                                  },
                       "use":  "@vercel/next",
                       "src":  "package.json"
                   }
               ],
    "framework":  "nextjs",
    "version":  2,
    "outputDirectory":  ".next"
}